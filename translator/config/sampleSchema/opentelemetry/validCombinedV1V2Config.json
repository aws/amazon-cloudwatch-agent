{
  "agent": {
    "metrics_collection_interval": 60,
    "region": "us-west-2",
    "debug": true
  },
  "metrics": {
    "metrics_collected": {
      "cpu": {
        "resources": ["*"],
        "measurement": ["cpu_usage_idle"],
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used"]
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/messages",
            "log_group_name": "/var/log/messages"
          }
        ]
      }
    }
  },
  "traces": {
    "traces_collected": {
      "xray": {}
    }
  },
  "opentelemetry": {
    "collect": {
      "host_insights": {
        "metrics_collection_interval": 60
      },
      "container_insights": {
        "cluster_name": "TestCluster",
        "collection_interval": 30
      },
      "database_insights": {
        "postgresql": [
          {
            "endpoint": "localhost:5432",
            "instance_name": "my-postgres",
            "username": "cw_monitor",
            "password_file": "/opt/.pgpass"
          }
        ]
      },
      "prometheus": {
        "config_path": "/etc/prometheus.yml"
      },
      "otlp": {
        "grpc_endpoint": "127.0.0.1:4327",
        "http_endpoint": "127.0.0.1:4328"
      }
    }
  }
}
