{
    "logs": {
        "logs_collected": {
            "journald": {
                "collect_list": [
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-regex1",
                        "retention_in_days": 1,
                        "filters": [
                            {"type": "include", "expression": "Database.*failed|Authentication.*|login.*"}
                        ]
                    },
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-regex2",
                        "retention_in_days": 1,
                        "filters": [
                            {"type": "include", "expression": ".*user.*"},
                            {"type": "exclude", "expression": ".*failed.*"}
                        ]
                    }
                ]
            }
        }
    }
}
