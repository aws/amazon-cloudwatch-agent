{
  "agent": {
    "region": "us-east-1"
  },
  "metrics": {
    "metrics_destinations": {
      "otlp": {
        "endpoint": "test-endpoint"
      },
      "cloudwatch": {
      }
    },
    "metrics_collected": {
      "cpu": {
        "measurement": [
          "cpu_usage_guest"
        ]
      }
