{
  "logs": {
    "concurrency": 1,
    "logs_collected": {
      "journald": {
        "collect_list": [
          {
            "log_group_name": "journald-root",
            "log_stream_name": "journald-stream",
            "matches": [{"_UID": "0"}, {"_TRANSPORT": "kernel"}],
            "retention_in_days": 7
          }
        ]
      }
    }
  }
}
