{
  "agent": {
    "region": "us-west-2"
  },
  "opentelemetry": {
    "collect": {
      "database_insights": {
        "mysql": [
          {
            "endpoint": "localhost:3306",
            "instance_name": "pentest-mysql",
            "username": "cw_monitor",
            "password_file": "sampleConfig/opentelemetry/testdata/.mysql_credentials",
            "logs": {
              "file_path": "/var/log/mysql/mysql.log"
            }
          }
        ]
      }
    }
  }
}
